# Delonixfile — same grammar as a Dockerfile, with Delonix extensions.
# Build with:  delonix build -t __NAME__:dev .
#
# pnpm-native (via corepack) + TypeScript. Single-stage (`delonix build` is
# single-stage). No non-root USER: in Delonix's rootless model uid 0 is already
# an unprivileged host uid, and a `chown` would make the flat rootfs unpackable.
FROM node:20-slim
ENV NODE_ENV=production
WORKDIR /app
# corepack ships with node and provisions the pnpm from package.json#packageManager.
RUN corepack enable
COPY package.json ./
COPY tsconfig.json ./
COPY src ./src
# install (incl. dev for the build) → compile TS → drop dev deps.
RUN pnpm install --prod=false && pnpm build && pnpm prune --prod
EXPOSE __PORT__
# Delonix extension: the runtime probes this to mark the container healthy.
HEALTHCHECK CMD node -e "require('http').get('http://127.0.0.1:__PORT__/api/v1/health/live',r=>process.exit(r.statusCode===200?0:1)).on('error',()=>process.exit(1))"
CMD ["node", "dist/index.js"]
