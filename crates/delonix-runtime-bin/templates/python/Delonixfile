# Delonixfile — same grammar as a Dockerfile, with Delonix extensions.
# Build with:  delonix build -t __NAME__:dev .
#
# uv-native (the modern Python tool). Single-stage on purpose: `delonix build` is
# single-stage (no multi-stage yet) and one instruction per line (no `\`). No
# non-root USER: in Delonix's rootless model the container's uid 0 is ALREADY an
# unprivileged host uid, and a `chown` would make the flat rootfs unpackable.
FROM python:3.12-slim
ENV PYTHONDONTWRITEBYTECODE=1 PYTHONUNBUFFERED=1 UV_COMPILE_BYTECODE=1 UV_LINK_MODE=copy UV_PROJECT_ENVIRONMENT=/app/.venv PATH=/app/.venv/bin:$PATH
WORKDIR /app
# uv, the resolver/installer (astral). Bootstrap it with pip (single line — the
# usual `COPY --from=ghcr.io/astral-sh/uv` is multi-stage, unsupported here).
RUN pip install --no-cache-dir uv
# delonix COPY takes the FINAL destination path (no Docker `COPY x ./` filename
# append), so give explicit absolute destinations.
COPY pyproject.toml /app/pyproject.toml
COPY src /app/src
# Resolve + install into /app/.venv (runtime deps only, no dev group).
RUN uv sync --no-dev
EXPOSE __PORT__
# Absolute venv paths: the exec-form CMD/HEALTHCHECK are resolved without the
# image's PATH, so point straight at the uv-provisioned venv binaries.
# Delonix extension: the runtime probes this to mark the container healthy.
HEALTHCHECK CMD /app/.venv/bin/python -c "import urllib.request;urllib.request.urlopen('http://127.0.0.1:__PORT__/api/v1/health/live')" || exit 1
CMD ["/app/.venv/bin/uvicorn", "__MODULE__.main:app", "--host", "0.0.0.0", "--port", "__PORT__"]
