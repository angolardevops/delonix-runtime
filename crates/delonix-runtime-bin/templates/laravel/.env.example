APP_NAME=__NAME__
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost:__PORT__

# Log to stderr so `delonix container logs` sees everything (12-factor).
LOG_CHANNEL=stderr
LOG_LEVEL=info

# SQLite by default → runs out of the box, no external DB. The file is created
# at build time (see Delonixfile). Swap for pgsql/mysql when you add models.
DB_CONNECTION=sqlite

SESSION_DRIVER=file
CACHE_STORE=file
QUEUE_CONNECTION=sync
