# Delonixfile — Django + gunicorn, uv-managed.
# Build with:  delonix build -t __NAME__:dev .
FROM python:3.12-slim
ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    UV_PROJECT_ENVIRONMENT=/app/.venv \
    DJANGO_SETTINGS_MODULE=config.settings
WORKDIR /app
RUN pip install --no-cache-dir uv
COPY pyproject.toml ./
COPY manage.py ./
COPY config ./config
RUN uv sync --no-dev
EXPOSE __PORT__
# Delonix extension: the runtime probes this to mark the container healthy.
HEALTHCHECK CMD /app/.venv/bin/python -c "import urllib.request;urllib.request.urlopen('http://127.0.0.1:__PORT__/api/v1/health/live')" || exit 1
CMD ["/app/.venv/bin/gunicorn", "config.wsgi:application", "-b", "0.0.0.0:__PORT__", "--workers", "2"]
