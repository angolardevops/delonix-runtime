# Delonixfile — production-ready nginx (static + reverse-proxy ready).
# Build with:  delonix build -t __NAME__:dev .
FROM nginx:1.27-alpine
COPY nginx.conf /etc/nginx/nginx.conf
COPY html /usr/share/nginx/html
EXPOSE __PORT__
# Delonix extension: the runtime probes this to mark the container healthy.
HEALTHCHECK CMD wget -qO- http://127.0.0.1:__PORT__/healthz || exit 1
CMD ["nginx", "-g", "daemon off;"]
